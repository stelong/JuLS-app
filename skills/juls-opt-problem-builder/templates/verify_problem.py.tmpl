"""Verify the {{PROBLEM}} problem is registered and solvable on a running JuLS image.

Generated by the juls-opt-problem-builder skill. Save as
clients/examples/verify_{{PROBLEM}}.py and run from the clients/ directory:

    uv run examples/verify_{{PROBLEM}}.py [BASE_URL]

Assumes the freshly built image is running (e.g. docker run -p 8080:8080 ...).
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from juls import JuLSClient

PROBLEM = "{{PROBLEM}}"
# A small valid instance of {{PROBLEM}} (the `data` payload only):
SAMPLE = {{SAMPLE_JSON}}


def verify(base_url: str = "http://localhost:8080") -> dict:
    """Confirm {{PROBLEM}} is registered, then solve the sample. Returns the response."""
    with JuLSClient(base_url) as client:
        schema = client.problems()
        assert PROBLEM in schema, f"{PROBLEM!r} not registered; available: {sorted(schema)}"
        fields = [f["name"] for f in schema[PROBLEM]]
        print(f"[ok] {PROBLEM} registered with fields: {fields}")

        res = client.solve(PROBLEM, SAMPLE, limit="auto", seed=0)
        r = res["result"]
        print(
            f"[ok] solved: status={res['status']} "
            f"objective={r['objective']} feasible={r['feasible']} "
            f"iterations={res['metrics']['iterations']}"
        )
        return res


if __name__ == "__main__":
    verify(*(sys.argv[1:2] or []))
